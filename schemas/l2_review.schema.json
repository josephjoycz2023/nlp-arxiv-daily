{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["highlight", "normal", "archive_only"]
    },
    "priority": {
      "type": "string",
      "enum": ["must_read", "useful", "background", "skip"]
    },
    "summary_cn": {
      "type": "string"
    },
    "research_goal_cn": {
      "type": "string"
    },
    "method_cn": {
      "type": "string"
    },
    "experiment_cn": {
      "type": "string"
    },
    "result_cn": {
      "type": "string"
    },
    "landing_value_cn": {
      "type": "string"
    },
    "module_assessments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "module_id": {
            "type": "string"
          },
          "module_name": {
            "type": "string"
          },
          "relevance": {
            "type": "string",
            "enum": ["high", "medium", "low", "none"]
          },
          "should_follow": {
            "type": "boolean"
          },
          "reason_cn": {
            "type": "string"
          },
          "evidence_cn": {
            "type": "string"
          }
        },
        "required": [
          "module_id",
          "module_name",
          "relevance",
          "should_follow",
          "reason_cn",
          "evidence_cn"
        ]
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relevance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "credibility": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "landing_feasibility": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "actionability": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      },
      "required": [
        "relevance",
        "credibility",
        "landing_feasibility",
        "actionability"
      ]
    },
    "risks_cn": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_action_cn": {
      "type": "string"
    }
  },
  "required": [
    "decision",
    "priority",
    "summary_cn",
    "research_goal_cn",
    "method_cn",
    "experiment_cn",
    "result_cn",
    "landing_value_cn",
    "module_assessments",
    "scores",
    "risks_cn",
    "recommended_action_cn"
  ]
}
