---
import { withBase } from "../utils/url.ts";
import type { DashboardData } from "../utils/personalizedDashboard.ts";

interface Props {
  dashboard: DashboardData;
}

const { dashboard } = Astro.props;
const tabs = dashboard.columns.map((column) => ({
  id: column.id,
  title: column.title,
  count: column.groups.reduce((count, group) => count + group.papers.length, 0),
}));
const digestColumn = dashboard.columns.find((column) => column.id === "digest");
const digestIndex = digestColumn?.groups.flatMap((group) => group.papers) ?? [];
const digestDirectionSummary =
  digestColumn?.groups
    .slice(0, 3)
    .map((group) => `${group.direction.shortLabel} ${group.papers.length}`)
    .join(" · ") ?? "";

function hrefForDate(date: string): string {
  return date === dashboard.latestDate ? withBase("/") : withBase(`/archive/${date}/`);
}

function toneClasses(tone: "accent" | "warning" | "muted" | "danger"): string {
  if (tone === "accent") {
    return "border-(--color-accent)/25 bg-(--color-accent-soft) text-(--color-accent-strong)";
  }
  if (tone === "warning") {
    return "border-[color:var(--color-warning-border)] bg-[color:var(--color-warning-bg)] text-[color:var(--color-warning-fg)]";
  }
  if (tone === "danger") {
    return "border-[color:var(--color-danger-border)] bg-[color:var(--color-danger-bg)] text-[color:var(--color-danger-fg)]";
  }
  return "border-(--color-border) bg-(--color-surface-strong) text-(--color-muted)";
}
---

<main class="mx-auto max-w-[1600px] px-4 py-8 lg:px-6">
  <div class="grid gap-6 lg:grid-cols-[290px_minmax(0,1fr)]">
    <aside class="space-y-4 self-start lg:sticky lg:top-6">
      <section class="rounded-[28px] border border-(--color-border) bg-(--color-surface) p-5 shadow-[var(--shadow-card)]">
        <p class="text-xs uppercase tracking-[0.22em] text-(--color-muted)">Date</p>
        <h1 class="mt-2 text-2xl font-semibold text-(--color-fg)">{dashboard.selectedDate}</h1>

        <label
          class="mt-5 block text-xs font-medium uppercase tracking-[0.18em] text-(--color-muted)"
          for="date-filter"
        >
          Switch Date
        </label>
        <select
          id="date-filter"
          class="mt-2 w-full rounded-2xl border border-(--color-border) bg-(--color-bg) px-4 py-3 text-sm text-(--color-fg) outline-none transition focus:border-(--color-accent)"
          data-date-filter
        >
          {dashboard.availableDates.map((date) => (
            <option value={hrefForDate(date)} selected={date === dashboard.selectedDate}>
              {date}
            </option>
          ))}
        </select>

        <div class="mt-5 grid grid-cols-2 gap-3">
          <article class="rounded-2xl bg-(--color-bg) px-4 py-3">
            <p class="text-xs uppercase tracking-[0.12em] text-(--color-muted)">Pool</p>
            <p class="mt-1 text-xl font-semibold">{dashboard.stats.poolCount}</p>
          </article>
          <article class="rounded-2xl bg-(--color-bg) px-4 py-3">
            <p class="text-xs uppercase tracking-[0.12em] text-(--color-muted)">Digest</p>
            <p class="mt-1 text-xl font-semibold">{dashboard.stats.digestMustRead}</p>
          </article>
          <article class="rounded-2xl bg-(--color-bg) px-4 py-3">
            <p class="text-xs uppercase tracking-[0.12em] text-(--color-muted)">L2</p>
            <p class="mt-1 text-xl font-semibold">{dashboard.stats.l2Count}</p>
          </article>
          <article class="rounded-2xl bg-(--color-bg) px-4 py-3">
            <p class="text-xs uppercase tracking-[0.12em] text-(--color-muted)">Archived</p>
            <p class="mt-1 text-xl font-semibold">{dashboard.stats.archivedCount}</p>
          </article>
        </div>
      </section>

      <section class="rounded-[28px] border border-(--color-border) bg-(--color-surface) p-5 shadow-[var(--shadow-card)]">
        <div class="flex items-center justify-between gap-3">
          <p class="text-xs uppercase tracking-[0.22em] text-(--color-muted)">Digest Index</p>
          <span class="text-xs text-(--color-muted)">{digestIndex.length}</span>
        </div>

        {digestIndex.length > 0 ? (
          <ol class="mt-4 space-y-3 text-sm leading-6">
            {digestIndex.map((paper, index) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-(--color-surface-strong) text-[11px] text-(--color-muted)">
                  {index + 1}
                </span>
                <a
                  class="min-w-0 text-(--color-fg) hover:text-(--color-accent-strong)"
                  href={paper.paperUrl ?? paper.pdfUrl ?? "#"}
                  target="_blank"
                  rel="noreferrer"
                >
                  {paper.title}
                </a>
              </li>
            ))}
          </ol>
        ) : (
          <p class="mt-4 text-sm text-(--color-muted)">No digest entries.</p>
        )}
      </section>
    </aside>

    <section class="space-y-6">
      <header class="rounded-[32px] border border-(--color-border) bg-[radial-gradient(circle_at_top_left,var(--color-hero-glow),transparent_55%),var(--color-surface)] p-6 shadow-[var(--shadow-card)]">
        <p class="text-xs uppercase tracking-[0.24em] text-(--color-muted)">Research Brief</p>
        <div class="mt-3 flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
          <div class="max-w-3xl">
            <h2 class="text-3xl font-semibold tracking-tight text-(--color-fg)">{dashboard.selectedDate}</h2>
            <p class="mt-3 text-sm leading-7 text-(--color-muted)">
              {`This pool contains ${dashboard.stats.poolCount} papers. Digest highlights ${dashboard.stats.digestMustRead} papers, and ${dashboard.stats.l2Count} papers passed L2.`}
              {digestDirectionSummary ? ` Top directions: ${digestDirectionSummary}.` : ""}
            </p>
          </div>
          <div class="flex flex-wrap gap-3 text-sm">
            <span class="rounded-full border border-(--color-border) bg-(--color-surface-strong) px-4 py-2 text-(--color-muted)">
              Watchlist {dashboard.stats.digestWatchlist}
            </span>
            <span class="rounded-full border border-(--color-border) bg-(--color-surface-strong) px-4 py-2 text-(--color-muted)">
              L1 Passed {dashboard.stats.l1Count}
            </span>
            <span class="rounded-full border border-(--color-border) bg-(--color-surface-strong) px-4 py-2 text-(--color-muted)">
              Rejected {dashboard.stats.rejectedCount}
            </span>
          </div>
        </div>
      </header>

      <section class="rounded-[28px] border border-(--color-border) bg-(--color-surface) p-3 shadow-[var(--shadow-card)]">
        <div class="flex flex-wrap gap-2" role="tablist" aria-label="Review stages">
          {tabs.map((tab) => (
            <button
              id={`tab-${tab.id}`}
              type="button"
              role="tab"
              data-tab={tab.id}
              data-active={tab.id === "digest" ? "true" : "false"}
              aria-selected={tab.id === "digest" ? "true" : "false"}
              aria-controls={`panel-${tab.id}`}
              tabindex={tab.id === "digest" ? "0" : "-1"}
              class:list={[
                "inline-flex items-center gap-3 rounded-2xl px-4 py-3 text-sm transition",
                tab.id === "digest"
                  ? "bg-(--color-accent) text-white"
                  : "bg-(--color-bg) text-(--color-muted) hover:text-(--color-fg)",
              ]}
            >
              <span>{tab.title}</span>
              <span
                class:list={[
                  "rounded-full px-2.5 py-0.5 text-xs",
                  tab.id === "digest"
                    ? "bg-white/18 text-white"
                    : "bg-(--color-surface-strong) text-(--color-muted)",
                ]}
              >
                {tab.count}
              </span>
            </button>
          ))}
        </div>
      </section>

      <div class="space-y-6">
        {dashboard.columns.map((column) => (
          <section
            id={`panel-${column.id}`}
            data-panel={column.id}
            role="tabpanel"
            aria-labelledby={`tab-${column.id}`}
            hidden={column.id !== "digest"}
            class="rounded-[28px] border border-(--color-border) bg-(--color-surface) shadow-[var(--shadow-card)]"
          >
            <header class="border-b border-(--color-border) px-5 py-4">
              <div class="flex items-center justify-between gap-3">
                <h3 class="text-lg font-semibold">{column.title}</h3>
                <span class="rounded-full border border-(--color-border) bg-(--color-surface-strong) px-3 py-1 text-xs text-(--color-muted)">
                  {column.groups.reduce((count, group) => count + group.papers.length, 0)}
                </span>
              </div>
            </header>

            <div class="space-y-5 px-5 py-5">
              {column.markdownHtml ? (
                <article class="digest-prose rounded-[24px] bg-(--color-bg) p-5" set:html={column.markdownHtml} />
              ) : null}

              {column.groups.length > 0 ? (
                column.groups.map((group) => (
                  <section class="space-y-3">
                    <div class="flex items-center justify-between gap-3">
                      <h4 class="text-sm font-semibold tracking-wide text-(--color-fg)">{group.direction.label}</h4>
                      <span class="text-xs text-(--color-muted)">{group.papers.length}</span>
                    </div>

                    <div class="space-y-3">
                      {group.papers.map((paper) => (
                        <article class="rounded-[24px] border border-(--color-border) bg-(--color-bg) p-4">
                          <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                              <h5 class="text-sm font-semibold leading-6 text-(--color-fg)">
                                <a
                                  class="hover:text-(--color-accent-strong)"
                                  href={paper.paperUrl ?? paper.pdfUrl ?? "#"}
                                  target="_blank"
                                  rel="noreferrer"
                                >
                                  {paper.title}
                                </a>
                              </h5>
                              <p class="mt-1 text-xs leading-5 text-(--color-muted)">
                                {paper.paperId}
                                {paper.publishedDate ? ` · ${paper.publishedDate}` : ""}
                              </p>
                            </div>
                            <span class:list={["shrink-0 rounded-full border px-3 py-1 text-[11px] font-medium", toneClasses(paper.statusTone)]}>
                              {paper.stageBadge}
                            </span>
                          </div>

                          {paper.authors.length > 0 ? (
                            <p class="mt-3 text-xs leading-5 text-(--color-muted)">{paper.authors.join(", ")}</p>
                          ) : null}

                          <div class="mt-3 flex flex-wrap gap-2">
                            <span class="rounded-full bg-(--color-surface-strong) px-3 py-1 text-[11px] text-(--color-muted)">
                              {paper.primaryDirection.label}
                            </span>
                            {paper.relevance !== null ? (
                              <span class="rounded-full bg-(--color-surface-strong) px-3 py-1 text-[11px] text-(--color-muted)">
                                Relevance {paper.relevance}
                              </span>
                            ) : null}
                            {paper.totalScore !== null ? (
                              <span class="rounded-full bg-(--color-surface-strong) px-3 py-1 text-[11px] text-(--color-muted)">
                                L1 Score {paper.totalScore}
                              </span>
                            ) : null}
                          </div>

                          {paper.trackLabels.length > 0 ? (
                            <div class="mt-3 flex flex-wrap gap-2">
                              {paper.trackLabels.map((track) => (
                                <span class="rounded-full border border-(--color-border) px-3 py-1 text-[11px] text-(--color-muted)">
                                  {track}
                                </span>
                              ))}
                            </div>
                          ) : null}

                          {paper.summary ? <p class="mt-4 text-sm leading-6 text-(--color-fg)">{paper.summary}</p> : null}

                          {paper.whyRelevant ? (
                            <p class="mt-3 text-sm leading-6 text-(--color-muted)">
                              <span class="font-medium text-(--color-fg)">Related:</span> {paper.whyRelevant}
                            </p>
                          ) : null}

                          {paper.recommendedAction ? (
                            <p class="mt-3 text-sm leading-6 text-(--color-muted)">
                              <span class="font-medium text-(--color-fg)">Next:</span> {paper.recommendedAction}
                            </p>
                          ) : null}

                          {paper.archiveReason ? (
                            <p class="mt-3 text-sm leading-6 text-(--color-muted)">
                              <span class="font-medium text-(--color-fg)">Archive note:</span> {paper.archiveReason}
                            </p>
                          ) : null}

                          {paper.failureMessage ? (
                            <p class="mt-3 text-sm leading-6 text-[color:var(--color-danger-fg)]">{paper.failureMessage}</p>
                          ) : null}

                          <div class="mt-4 flex flex-wrap gap-3 text-xs">
                            {paper.paperUrl ? (
                              <a
                                class="text-(--color-accent-strong) hover:underline"
                                href={paper.paperUrl}
                                target="_blank"
                                rel="noreferrer"
                              >
                                arXiv
                              </a>
                            ) : null}
                            {paper.pdfUrl ? (
                              <a
                                class="text-(--color-accent-strong) hover:underline"
                                href={paper.pdfUrl}
                                target="_blank"
                                rel="noreferrer"
                              >
                                PDF
                              </a>
                            ) : null}
                            {paper.codeLink ? (
                              <a
                                class="text-(--color-accent-strong) hover:underline"
                                href={paper.codeLink}
                                target="_blank"
                                rel="noreferrer"
                              >
                                Code
                              </a>
                            ) : null}
                          </div>
                        </article>
                      ))}
                    </div>
                  </section>
                ))
              ) : (
                <div class="rounded-[24px] border border-dashed border-(--color-border) bg-(--color-bg) px-4 py-5 text-sm leading-6 text-(--color-muted)">
                  No results.
                </div>
              )}
            </div>
          </section>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    const dateFilter = document.querySelector("[data-date-filter]");
    if (dateFilter instanceof HTMLSelectElement) {
      dateFilter.addEventListener("change", (event) => {
        const nextUrl = event.currentTarget.value;
        if (nextUrl) {
          window.location.assign(nextUrl);
        }
      });
    }

    const tabs = Array.from(document.querySelectorAll("[data-tab]"));
    const panels = Array.from(document.querySelectorAll("[data-panel]"));

    const setActiveTab = (tabId) => {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.tab === tabId;
        tab.dataset.active = isActive ? "true" : "false";
        tab.setAttribute("aria-selected", isActive ? "true" : "false");
        tab.setAttribute("tabindex", isActive ? "0" : "-1");
        tab.classList.toggle("bg-(--color-accent)", isActive);
        tab.classList.toggle("text-white", isActive);
        tab.classList.toggle("bg-(--color-bg)", !isActive);
        tab.classList.toggle("text-(--color-muted)", !isActive);

        const count = tab.querySelector("span:last-child");
        if (count) {
          count.classList.toggle("bg-white/18", isActive);
          count.classList.toggle("text-white", isActive);
          count.classList.toggle("bg-(--color-surface-strong)", !isActive);
          count.classList.toggle("text-(--color-muted)", !isActive);
        }
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.panel !== tabId;
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const tabId = tab.dataset.tab;
        if (!tabId) return;
        setActiveTab(tabId);
        window.history.replaceState({}, "", `${window.location.pathname}#${tabId}`);
      });
    });

    const initialTab = window.location.hash.replace("#", "");
    if (initialTab && tabs.some((tab) => tab.dataset.tab === initialTab)) {
      setActiveTab(initialTab);
    } else {
      setActiveTab("digest");
    }
  </script>
</main>
