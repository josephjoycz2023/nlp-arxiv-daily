---
import PersonalizedDashboard from "../components/PersonalizedDashboard.astro";
import Layout from "../layouts/Layout.astro";
import { getDashboardData } from "../utils/personalizedDashboard.ts";

const dashboard = getDashboardData();
---

<Layout
  title="Personalized Research Dashboard"
  description="Pool-date based dashboard for Digest, L2, L1, and Archived personalized paper reviews."
  current="home"
>
  <PersonalizedDashboard dashboard={dashboard} />
</Layout>
