---
import Search from "astro-pagefind/components/Search";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Search Personalized Snapshots"
  description="Full-text search across personalized dashboards, digests, and archived pool snapshots."
  current="search"
>
  <main class="mx-auto max-w-[1100px] px-4 py-8 lg:px-6">
    <header class="mb-6 rounded-[28px] border border-(--color-border) bg-(--color-surface) p-6 shadow-[var(--shadow-card)]">
      <h1 class="text-4xl font-bold mb-2">Search</h1>
      <p class="text-(--color-muted) text-sm">
        Full-text across personalized dashboards, digests, and archived pool-date snapshots.
      </p>
    </header>

    <Search
      id="search"
      className="pagefind-ui"
      uiOptions={{
        showImages: false,
        showSubResults: true,
        autofocus: true,
        debounceTimeoutMs: 150,
      }}
    />
  </main>

  <script>
    const sync = () => {
      const input = document.querySelector("#search input[type='text']");
      if (!(input instanceof HTMLInputElement)) return;

      const url = new URL(window.location.href);
      const initial = url.searchParams.get("q");
      if (initial) {
        input.value = initial;
        input.dispatchEvent(new Event("input", { bubbles: true }));
      }

      input.addEventListener("input", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;

        const nextUrl = new URL(window.location.href);
        if (target.value) {
          nextUrl.searchParams.set("q", target.value);
        } else {
          nextUrl.searchParams.delete("q");
        }
        window.history.replaceState({}, "", nextUrl);
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", sync);
    } else {
      sync();
    }
  </script>

  <style is:global>
    :root {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: var(--color-accent);
      --pagefind-ui-text: var(--color-fg);
      --pagefind-ui-background: var(--color-bg);
      --pagefind-ui-border: var(--color-border);
      --pagefind-ui-tag: var(--color-surface);
      --pagefind-ui-border-radius: 16px;
      --pagefind-ui-font: var(--font-sans);
    }
  </style>
</Layout>
