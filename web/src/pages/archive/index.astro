---
import Layout from "../../layouts/Layout.astro";
import { withBase } from "../../utils/url.ts";
import { getDashboardSummaries } from "../../utils/personalizedDashboard.ts";

const summaries = getDashboardSummaries();
---

<Layout
  title="Pool Date Archive"
  description="Browse personalized paper-review snapshots by pool date."
  current="archive"
  ogSlug="archive"
>
  <main class="mx-auto max-w-[1100px] px-4 py-8 lg:px-6">
    <header class="rounded-[32px] border border-(--color-border) bg-(--color-surface) p-6 shadow-[var(--shadow-card)]">
      <p class="text-xs uppercase tracking-[0.24em] text-(--color-muted)">Archive</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight">Pool-Date Snapshots</h1>
      <p class="mt-3 max-w-2xl text-sm leading-7 text-(--color-muted)">
        每个条目对应一次固定的 personalized paper pool。点击日期后，页面展示的是该 pool
        中经过 L1、L2 和 Digest 处理后的整套结果，而不是某一天新发表的论文集合。
      </p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-2">
      {summaries.map((summary) => (
        <a
          class="rounded-[28px] border border-(--color-border) bg-(--color-surface) p-5 shadow-[var(--shadow-card)] transition hover:border-(--color-accent) hover:-translate-y-0.5"
          href={summary.date === summaries[0]?.date ? withBase("/") : withBase(`/archive/${summary.date}/`)}
        >
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-(--color-muted)">Pool Date</p>
              <h2 class="mt-2 text-2xl font-semibold">{summary.date}</h2>
            </div>
            {summary.date === summaries[0]?.date ? (
              <span class="rounded-full border border-(--color-accent) bg-(--color-accent-soft) px-3 py-1 text-xs text-(--color-accent-strong)">
                Latest
              </span>
            ) : null}
          </div>

          <div class="mt-5 grid grid-cols-2 gap-3 text-sm">
            <div class="rounded-2xl bg-(--color-bg) px-4 py-3">
              <p class="text-xs uppercase tracking-[0.12em] text-(--color-muted)">Pool</p>
              <p class="mt-1 text-lg font-semibold">{summary.poolCount}</p>
            </div>
            <div class="rounded-2xl bg-(--color-bg) px-4 py-3">
              <p class="text-xs uppercase tracking-[0.12em] text-(--color-muted)">Digest</p>
              <p class="mt-1 text-lg font-semibold">{summary.digestMustRead}</p>
            </div>
            <div class="rounded-2xl bg-(--color-bg) px-4 py-3">
              <p class="text-xs uppercase tracking-[0.12em] text-(--color-muted)">L2</p>
              <p class="mt-1 text-lg font-semibold">{summary.l2Count}</p>
            </div>
            <div class="rounded-2xl bg-(--color-bg) px-4 py-3">
              <p class="text-xs uppercase tracking-[0.12em] text-(--color-muted)">Archived</p>
              <p class="mt-1 text-lg font-semibold">{summary.archivedCount}</p>
            </div>
          </div>
        </a>
      ))}
    </section>
  </main>
</Layout>
