---
import PersonalizedDashboard from "../../components/PersonalizedDashboard.astro";
import Layout from "../../layouts/Layout.astro";
import { getAvailablePoolDates, getDashboardData } from "../../utils/personalizedDashboard.ts";

export async function getStaticPaths() {
  return getAvailablePoolDates().map((date) => ({
    params: { month: date },
  }));
}

const { month } = Astro.params;

if (!month) {
  throw new Error("Missing pool date route parameter.");
}

const dashboard = getDashboardData(month);
---

<Layout
  title={`Pool ${dashboard.selectedDate}`}
  description={`Personalized dashboard for the ${dashboard.selectedDate} pool snapshot.`}
  current="archive"
  ogSlug={`archive/${dashboard.selectedDate}`}
>
  <PersonalizedDashboard dashboard={dashboard} />
</Layout>
